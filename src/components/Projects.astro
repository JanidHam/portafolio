---
const projects = [
  {
    name: "PeopleCor",
    company: "PeopleCor",
    url: "https://peoplecor.com",
    urlLabel: "peoplecor.com",
    desc: "Time clock system for dairies. Full stack platform with React, Node.js and PostgreSQL. 60% improvement in load times.",
    tags: ["React", "Node.js", "Laravel", "PostgreSQL", "Google Cloud"],
  },
  {
    name: "TheGeekChronicles",
    company: "Independent",
    url: "https://thegeekchronicles.app",
    urlLabel: "thegeekchronicles.app",
    desc: "Cross-platform mobile app with AI-driven content workflows and automated publishing pipelines. Built end-to-end independently.",
    tags: ["React Native", "Node.js", "Python", "AWS", "PostgreSQL"],
    appStore: "https://apps.apple.com/mx/app/the-geek-chronicles/id6478323387",
    playStore: "https://play.google.com/store/apps/details?id=app.thegeekchronicles.thegeekchroniclesapp&hl=en",
  },
  {
    name: "Catholic Social Media",
    company: "FounderWorkshop",
    url: "https://prengersolutions.com/catholic-social-media/",
    urlLabel: "prengersolutions.com",
    desc: "Social media platform built with React and serverless Node.js on AWS Lambda. Automated deployments via Bitbucket Pipelines.",
    tags: ["React", "Node.js", "AWS Lambda", "PostgreSQL"],
  },
  {
    name: "AskGenius",
    company: "FounderWorkshop",
    url: "https://prengersolutions.com/products/askgenius/",
    urlLabel: "prengersolutions.com",
    desc: "Serverless B2B web app built with React and AWS Lambda. Automated deployments via Bitbucket Pipelines.",
    tags: ["React", "TypeScript", "AWS Lambda", "Node.js"],
  },
];
---

<section class="projects" id="projects">
  <div class="inner">
    <p class="label">// projects</p>
    <div class="grid">
      {projects.map(project => (
        <div class="card">
          <div class="card-top">
            <div>
              <p class="project-name">{project.name}</p>
              <p class="project-company">{project.company}</p>
            </div>
            {project.url ? (
              <a href={project.url} target="_blank" rel="noopener" class="project-link">
                {project.urlLabel}
              </a>
            ) : (
              <span class="project-link-static">{project.urlLabel}</span>
            )}
          </div>
          <p class="project-desc">{project.desc}</p>
          <div class="tags">
            {project.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          {project.appStore && (
            <div class="store-links">
              <a href={project.appStore} target="_blank" rel="noopener" class="store-link">App Store</a>
              <a href={project.playStore} target="_blank" rel="noopener" class="store-link">Play Store</a>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    border-bottom: 1px solid var(--border);
  }

  .inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--accent-green);
    letter-spacing: 3px;
    margin-bottom: 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--border-hover);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .project-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .project-company {
    font-size: 11px;
    color: var(--text-muted);
  }

  .project-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--accent-blue);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .project-link:hover {
    opacity: 0.75;
  }

  .project-link-static {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .project-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 20px;
  }

  .store-links {
    display: flex;
    gap: 6px;
    margin-top: 2px;
  }

  .store-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--accent-purple);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .store-link:hover {
    opacity: 0.75;
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>